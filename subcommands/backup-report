#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=config
source "$PLUGIN_ROOT/config"
# shellcheck source=functions
source "$PLUGIN_ROOT/functions"

cmd_backup_report() {
  local auth="no"
  filelogs_backup_auth_exists && auth="yes"

  local docker_present="no"
  command -v "$FILELOGS_DOCKER_BIN" >/dev/null 2>&1 && docker_present="yes"

  local image_present="no"
  if [[ "$docker_present" = "yes" ]] && \
     "$FILELOGS_DOCKER_BIN" image inspect "$FILELOGS_AWS_IMAGE" >/dev/null 2>&1; then
    image_present="yes"
  fi

  local region endpoint bucket prefix schedule candidates
  region=$(filelogs_backup_cred_get AWS_DEFAULT_REGION)
  endpoint=$(filelogs_backup_cred_get FILELOGS_S3_ENDPOINT)
  bucket=$(filelogs_backup_get bucket)
  prefix=$(filelogs_backup_get prefix)
  schedule=$(filelogs_backup_get schedule)

  # Render a unix timestamp via portable date(1). Falls back to the raw
  # epoch if neither GNU nor BSD date can format it.
  format_ts() {
    local ts="$1"
    [[ -z "$ts" ]] && { echo "never"; return 0; }
    date -u -r "$ts" 2>/dev/null \
      || date -u -d "@$ts" 2>/dev/null \
      || echo "$ts"
  }

  local last_attempt last_success last_error_line
  last_attempt=$(format_ts "$(filelogs_backup_get last-attempt)")
  last_success=$(format_ts "$(filelogs_backup_get last-success)")
  last_error_line=$(filelogs_backup_get last-error)

  candidates=$(filelogs_list_backup_candidates | wc -l | tr -d ' ')

  cat <<EOF
=====> filelogs backup report
       docker present:   $docker_present
       aws image:        $FILELOGS_AWS_IMAGE ($( [[ "$image_present" = "yes" ]] && echo "pulled" || echo "not pulled" ))
       credentials:      $auth
       region:           ${region:-<unset>}
       endpoint:         ${endpoint:-<default AWS>}
       bucket:           ${bucket:-<unset>}
       prefix:           ${prefix:-<none>}
       schedule (cron):  ${schedule:-<none>}
       cron file:        $FILELOGS_CRON_FILE $( [[ -f "$FILELOGS_CRON_FILE" ]] && echo "(present)" || echo "(absent)" )
       last attempt:     $last_attempt
       last success:     $last_success
       last error:       ${last_error_line:-<none>}
       candidate apps:   $candidates
EOF
}

cmd_backup_report "$@"
