#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=config
source "$PLUGIN_ROOT/config"
# shellcheck source=functions
source "$PLUGIN_ROOT/functions"

stream_file() {
  local f="$1"
  if [[ "$f" = *.gz ]]; then
    gunzip -c "$f"
  else
    cat "$f"
  fi
}

cmd_tail() {
  local cmd="${PLUGIN_COMMAND_PREFIX}:tail"
  [[ "${1:-}" == "$cmd" ]] && shift

  local app="" date_arg="" lines=100 follow=0 raw=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --date)          date_arg="${2:-}"; shift 2 ;;
      --date=*)        date_arg="${1#*=}"; shift ;;
      --at)            date_arg="${2:-}"; shift 2 ;;
      --at=*)          date_arg="${1#*=}"; shift ;;
      --lines|-n)      lines="${2:-100}"; shift 2 ;;
      --lines=*)       lines="${1#*=}"; shift ;;
      --follow|-f)     follow=1; shift ;;
      --raw)           raw=1; shift ;;
      -*)              echo "unknown flag: $1" >&2; exit 1 ;;
      *)
        if [[ -z "$app" ]]; then
          app="$1"
        else
          echo "unexpected arg: $1" >&2
          exit 1
        fi
        shift ;;
    esac
  done

  if [[ -z "$app" ]]; then
    echo "usage: dokku ${PLUGIN_COMMAND_PREFIX}:tail <app> [--date YYYY-MM-DD[THH]] [--lines N] [--follow] [--raw]" >&2
    exit 1
  fi

  local dir="$FILELOGS_LOG_ROOT/$app"

  # --follow only applies to the current open file.
  if (( follow == 1 )); then
    local current
    current="$dir/$(filelogs_current_log_name "$app")"
    if [[ ! -f "$current" ]]; then
      echo "no current log file at $current" >&2
      exit 1
    fi
    if (( raw == 1 )); then
      tail -n "$lines" -F "$current"
    else
      tail -n "$lines" -F "$current" | filelogs_format_line_plain
    fi
    return
  fi

  # Resolve basename pattern.
  local basename_pattern
  if [[ -n "$date_arg" ]]; then
    if [[ "$date_arg" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
      # Matches daily (2026-04-22.log) AND all hourly files of that day
      # (2026-04-22T00.log .. 2026-04-22T23.log).
      basename_pattern="${date_arg}*.log"
    elif [[ "$date_arg" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}$ ]]; then
      basename_pattern="${date_arg}.log"
    else
      echo "invalid date: $date_arg (use YYYY-MM-DD or YYYY-MM-DDTHH)" >&2
      exit 1
    fi
  else
    basename_pattern="$(filelogs_current_log_name "$app")"
  fi

  # Collect matches (plain + gzipped), sort by name (names sort chronologically).
  local files=()
  while IFS= read -r f; do
    [[ -n "$f" ]] && files+=("$f")
  done < <(find "$dir" -maxdepth 1 -type f \
             \( -name "$basename_pattern" -o -name "${basename_pattern}.gz" \) \
             2>/dev/null | sort)

  if (( ${#files[@]} == 0 )); then
    echo "no logs matching '$basename_pattern' under $dir" >&2
    exit 1
  fi

  if (( raw == 1 )); then
    {
      for f in "${files[@]}"; do
        stream_file "$f"
      done
    } | tail -n "$lines"
  else
    {
      for f in "${files[@]}"; do
        stream_file "$f"
      done
    } | tail -n "$lines" | filelogs_format_line_plain
  fi
}

cmd_tail "$@"
