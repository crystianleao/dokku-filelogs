#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=config
source "$PLUGIN_ROOT/config"
# shellcheck source=functions
source "$PLUGIN_ROOT/functions"

report_app() {
  local app="$1"
  local log_dir="$FILELOGS_LOG_ROOT/$app"
  local enabled="no"
  filelogs_app_is_enabled "$app" && enabled="yes"

  local used_bytes used_human
  used_bytes=$(filelogs_dir_bytes "$log_dir")
  used_human=$(filelogs_bytes_to_human "$used_bytes")

  local max_app
  max_app=$(filelogs_get_value "$app" max-app-bytes)

  local retention
  retention=$(filelogs_get_value "$app" retention-days)

  local format
  format=$(filelogs_get_value "$app" format)

  local compress
  compress=$(filelogs_get_value "$app" compress)

  local current_bytes current_human current_cap
  current_bytes=$(filelogs_current_log_bytes "$app")
  current_human=$(filelogs_bytes_to_human "$current_bytes")
  current_cap=$(filelogs_get_value "$app" max-current-log-bytes)

  local sink_path sink_status
  sink_path=$(filelogs_vector_sink_path_for_app "$app")
  if filelogs_vector_has_sink_for_app "$app"; then
    sink_status="ok"
  elif [[ -z "$sink_path" ]]; then
    sink_status="missing"
  else
    sink_status="invalid"
  fi

  cat <<EOF
=====> $app filelogs information
       enabled:          $enabled
       log dir:          $log_dir
       disk used:        $used_human
       current log:      $current_human (cap: $current_cap)
       retention-days:   $retention
       max-app-bytes:    $max_app
       format:           $format
       compress:         $compress
       rotation:         $(filelogs_get_value "$app" rotation)
       vector sink:      $sink_status${sink_path:+ ($sink_path)}
EOF
}

report_global() {
  local total total_human max_total free_pct threshold pressure
  total=$(filelogs_dir_bytes "$FILELOGS_LOG_ROOT")
  total_human=$(filelogs_bytes_to_human "$total")
  max_total=$(filelogs_get_value --global max-total-bytes)
  free_pct=$(filelogs_free_percent "$FILELOGS_LOG_ROOT")
  threshold=$(filelogs_get_value --global min-free-disk-percent)
  pressure="ok"
  (( free_pct < threshold )) && pressure="LOW"

  local vstate vname vcfg
  vstate=$(filelogs_vector_status)
  vname=$(filelogs_vector_container_name)
  vcfg=$(filelogs_vector_config_path)

  cat <<EOF
=====> filelogs global report
       log root:                 $FILELOGS_LOG_ROOT
       disk used (all apps):     $total_human
       disk free:                ${free_pct}% (threshold: ${threshold}%, status: $pressure)
       max-total-bytes:          $max_total
       retention-days:           $(filelogs_get_value --global retention-days)
       max-app-bytes:            $(filelogs_get_value --global max-app-bytes)
       format:                   $(filelogs_get_value --global format)
       compress:                 $(filelogs_get_value --global compress)
       auto-enable:              $(filelogs_get_value --global auto-enable)
       min-free-disk-percent:    $threshold
       rotation (default):       $(filelogs_get_value --global rotation)
       max-current-log-bytes:    $(filelogs_get_value --global max-current-log-bytes)
       pressure-auto-downgrade:  $(filelogs_get_value --global pressure-auto-downgrade)
       vector container:         ${vstate}${vname:+ ($vname)}
       vector config:            $vcfg
EOF
}

cmd_report() {
  local cmd="${PLUGIN_COMMAND_PREFIX}:report"
  [[ "${1:-}" == "$cmd" ]] && shift
  local app="${1:-}"

  if [[ -n "$app" ]]; then
    report_app "$app"
    return
  fi

  report_global
  local a
  while IFS= read -r a; do
    [[ -n "$a" ]] && report_app "$a"
  done < <(filelogs_list_apps)
}

cmd_report "$@"
