#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=config
source "$PLUGIN_ROOT/config"

OWNER="${FILELOGS_OWNER:-dokku}"
GROUP="${FILELOGS_GROUP:-dokku}"

install -d -m 0755 "$FILELOGS_LOG_ROOT"
install -d -m 0755 "$FILELOGS_CONFIG_ROOT"
install -d -m 0755 "$FILELOGS_CONFIG_ROOT/apps"
install -d -m 0700 "$FILELOGS_CONFIG_ROOT/backup"

if id -u "$OWNER" >/dev/null 2>&1; then
  chown "$OWNER:$GROUP" \
    "$FILELOGS_LOG_ROOT" \
    "$FILELOGS_CONFIG_ROOT" \
    "$FILELOGS_CONFIG_ROOT/apps" \
    "$FILELOGS_CONFIG_ROOT/backup"
fi

# Install systemd timer if available.
if command -v systemctl >/dev/null 2>&1 && [[ -d /etc/systemd/system ]]; then
  sed "s|__PLUGIN_ROOT__|$PLUGIN_ROOT|g; s|__OWNER__|$OWNER|g; s|__GROUP__|$GROUP|g" \
    "$PLUGIN_ROOT/systemd/dokku-filelogs.service.tmpl" \
    > /etc/systemd/system/dokku-filelogs.service

  install -m 0644 "$PLUGIN_ROOT/systemd/dokku-filelogs.timer" \
    /etc/systemd/system/dokku-filelogs.timer

  systemctl daemon-reload
  systemctl enable --now dokku-filelogs.timer || true
fi

echo "-----> filelogs installed (log root: $FILELOGS_LOG_ROOT)"
