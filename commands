#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=config
source "$PLUGIN_ROOT/config"

case "$1" in
  help)
    # Top-level `dokku help`: emit one summary line. Full command list
    # lives behind `dokku ${PLUGIN_COMMAND_PREFIX}:help` to match the
    # convention used by core Dokku plugins.
    cat <<EOF
    ${PLUGIN_COMMAND_PREFIX}, persist Dokku app logs to daily files with per-app + global disk caps
EOF
    ;;
  "${PLUGIN_COMMAND_PREFIX}:help")
    cat <<EOF
    ${PLUGIN_COMMAND_PREFIX}:enable <app>                 Enable file logging for app
    ${PLUGIN_COMMAND_PREFIX}:disable <app>                Disable file logging for app
    ${PLUGIN_COMMAND_PREFIX}:set <app|--global> <k> <v>   Set config key (retention-days, max-app-bytes, max-total-bytes, format (json|text|compact), compress, auto-enable, min-free-disk-percent, rotation, backup-exclude, max-current-log-bytes, pressure-auto-downgrade)
    ${PLUGIN_COMMAND_PREFIX}:report [<app>]               Show status + disk usage
    ${PLUGIN_COMMAND_PREFIX}:doctor [<app>]               Run health checks (vector, config, sinks, GC timer)
    ${PLUGIN_COMMAND_PREFIX}:gc                           Force a garbage-collection run
    ${PLUGIN_COMMAND_PREFIX}:tail <app> [--date YYYY-MM-DD] [--at YYYY-MM-DDTHH] [--lines N] [--follow] [--raw]  Tail log (plain render by default; --raw for JSON)
    ${PLUGIN_COMMAND_PREFIX}:backup <app>|--all [--bucket <b>] [--prefix <p>]     Sync rotated logs to S3
    ${PLUGIN_COMMAND_PREFIX}:backup-auth <key> <secret> [region] [endpoint]      Store S3 credentials
    ${PLUGIN_COMMAND_PREFIX}:backup-deauth                                       Remove S3 credentials
    ${PLUGIN_COMMAND_PREFIX}:backup-schedule "<cron>" --bucket <b> [--prefix <p>] Write /etc/cron.d schedule
    ${PLUGIN_COMMAND_PREFIX}:backup-unschedule                                   Remove cron schedule
    ${PLUGIN_COMMAND_PREFIX}:backup-report                                       Show backup config + last run
EOF
    ;;
  *)
    exit "$DOKKU_NOT_IMPLEMENTED_EXIT"
    ;;
esac
